@page "/"

<PageTitle>Workbench</PageTitle>

@* The landing page now behaves as the central hosted tab surface instead of rendering the generated Radzen welcome experience. *@
@if (OpenTabs.Count == 0)
{
    <section class="workbench-tool-surface-state" aria-live="polite">
        <h1>No Workbench tab is open</h1>
        <p>Return to the explorer and double-click an item to open it in the center work surface.</p>
    </section>
}
else
{
    @* Every open tab stays mounted so inactive tabs preserve in-memory component state while they remain open. *@
    <div class="workbench-tool-surface-host">
        @foreach (var openTab in OpenTabs)
        {
            <section class="@GetTabPaneCss(openTab)" data-tab-id="@openTab.Id" aria-hidden="@(!IsTabActive(openTab))">
                <ErrorBoundary>
                    <ChildContent>
                        <DynamicComponent @key="openTab.ToolInstance.InstanceId" Type="openTab.ToolInstance.Definition.ComponentType" Parameters="GetToolParameters(openTab.ToolInstance)" />
                    </ChildContent>
                    <ErrorContent>
                        <section class="workbench-tool-surface-state workbench-tool-surface-state--error" aria-live="assertive">
                            <h1>Unable to render the selected tool</h1>
                            <p>The selected tool failed while rendering. Refresh the page or inspect the server logs for more detail.</p>
                        </section>
                    </ErrorContent>
                </ErrorBoundary>
            </section>
        }
    </div>
}

