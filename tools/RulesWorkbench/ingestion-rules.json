{
	"schemaVersion": "1.0",
	"rules": {
		"file-share": [
			{
				"id": "is-s57-exchange-set",
				"description": "When businessUnit is 'adds-s57', enrich as S-57 exchange set.",
				"if": {
					"all": [
						{
							"path": "properties[\"edition number\"]",
							"exists": true
						},
						{ "properties[\"businessUnitName\"]": "adds-s57" }
					]
				},
				"then": {
					"keywords": {
						"add": [
							"S57",
							"S-57",
							"ExchangeSet",
							"ENC"
						]
					},
					"searchText": {
						"add": [
							"S57 S-57 Exchange Sets"
						]
					},
					"category": {
						"add": [
							"Exchange Set"
						]
					},
					"series": {
						"add": [
							"S57",
							"S-57"
						]
					},
					"instance": {
						"add": [
							"$path:properties[\"product name\"]"
						]
					}
				}
			},
			{
				"id": "is-s100-exchange-set",
				"description": "When businessUnit is 'adds-s100', enrich as S-100 exchange set.",
				"if": {
					"all": [
						{
							"path": "properties[\"edition number\"]",
							"exists": true
						},
						{ "properties[\"businessUnitName\"]": "adds-s100" }
					]
				},
				"then": {
					"keywords": {
						"add": [
							"S100",
							"S-100",
							"ExchangeSet",
							"ENC"
						]
					},
					"searchText": {
						"add": [
							"S100 S-100 Exchange Sets"
						]
					},
					"category": {
						"add": [
							"Exchange Set"
						]
					},
					"series": {
						"add": [
							"S100",
							"S-100"
						]
					},
					"instance": {
						"add": [
							"$path:properties[\"product name\"]"
						]
					}
				}
			}
		]
	}
}